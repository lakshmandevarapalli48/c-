
class Solution {
  public:
    int binaryToDecimal(string &b) {
        int decimalValue = 0;
        int base = 1; // This represents 2^0 initially
        
        // Traverse the string from right to left
        for (int i = b.length() - 1; i >= 0; i--) {
            if (b[i] == '1') {
                decimalValue += base;
            }
            base = base * 2; // Move to the next power of 2
        }
        
        return decimalValue;
    }
};
